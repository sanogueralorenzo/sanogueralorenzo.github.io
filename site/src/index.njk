---
layout: base.njk
---
<main class="page-shell">
  <section class="hero-stage">
    <div class="hero-copy">
      {% if site.hero.eyebrow %}
        <p class="hero-eyebrow">{{ site.hero.eyebrow }}</p>
      {% endif %}
      <h1>{{ site.hero.title }}</h1>
      {% if site.hero.subline %}
        <p class="hero-subline">{{ site.hero.subline }}</p>
      {% endif %}
      {% if site.hero.intro %}
        <p class="hero-intro">{{ site.hero.intro }}</p>
      {% endif %}
    </div>

    <figure class="hero-drift">
      <img src="{{ site.hero.image }}" alt="{{ site.hero.imageAlt }}">
    </figure>

    {% if site.hero.noteTitle and site.hero.note %}
      <div class="hero-note">
        <span>{{ site.hero.noteTitle }}</span>
        <p>{{ site.hero.note }}</p>
      </div>
    {% endif %}
  </section>

  <nav class="line-links" aria-label="Profile links">
    {% for link in site.links %}
      <a class="line-link-pill" href="{{ link.url }}" target="_blank" rel="noreferrer" aria-label="{{ link.name }}" title="{{ link.name }}">
        <span>{{ link.label or (link.name | lower) }}</span>
      </a>
    {% endfor %}
  </nav>

  <section class="profile-section">
    <div class="profile-ribbon">
      <img class="profile-image" src="{{ site.profile.image }}" alt="{{ site.profile.imageAlt }}">
      <div class="profile-copy">
        <h2 class="profile-name">{{ site.title }}</h2>
        <p class="profile-blurb">{{ site.profile.blurb }}</p>
      </div>
    </div>
  </section>

  <section class="posts-section">
    <div class="posts-layout">
      <div class="section-heading posts-heading">
        <p class="section-label">{{ site.postsIntro.label }}</p>
        <p class="section-intro">{{ site.postsIntro.text }}</p>
      </div>
      <div class="posts-list">
        {% for post in collections.posts | reverse %}
          <article class="post-card">
            <a class="post-link" href="{{ post.url }}">
              <p class="post-card-date">{{ post.date | displayDate }}</p>
              <div class="post-card-body">
                <h2>{{ post.data.title }}</h2>
                {% if post.data.excerpt %}
                  <p class="post-card-excerpt">{{ post.data.excerpt }}</p>
                {% endif %}
              </div>
            </a>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>
</main>
