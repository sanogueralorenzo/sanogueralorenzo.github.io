---
layout: base.njk
---
<main class="page-shell">
  <section class="hero-section">
    <div class="hero-copy">
      <p class="hero-eyebrow">{{ site.hero.eyebrow }}</p>
      <h1>{{ site.hero.title }}</h1>
      <p class="hero-intro">{{ site.hero.intro }}</p>
      <div class="hero-actions">
        {% for action in site.actions %}
          <a class="button {% if loop.first %}button-primary{% else %}button-secondary{% endif %}" href="{{ action.url }}" target="_blank" rel="noreferrer">{{ action.label }}</a>
        {% endfor %}
      </div>
    </div>
    <figure class="hero-media">
      <img src="{{ site.hero.image }}" alt="{{ site.hero.imageAlt }}">
      <figcaption>
        <span>{{ site.hero.noteTitle }}</span>
        <p>{{ site.hero.note }}</p>
      </figcaption>
    </figure>
  </section>

  <section class="about-section">
    <div class="about-card">
      <img class="profile-image" src="{{ site.profile.image }}" alt="{{ site.profile.imageAlt }}">
      <div class="about-copy">
        <h2 class="profile-name">{{ site.title }}</h2>
        <p class="profile-blurb">{{ site.profile.blurb }}</p>
        <div class="profile-links" aria-label="Profile links">
          {% for link in site.links %}
            <a class="icon-link" href="{{ link.url }}" target="_blank" rel="noreferrer" aria-label="{{ link.name }}" title="{{ link.name }}">
              <span>{{ link.iconText }}</span>
            </a>
          {% endfor %}
        </div>
      </div>
    </div>
  </section>

  <section class="posts-section">
    <div class="section-heading posts-heading">
      <p class="section-label">{{ site.postsIntro.label }}</p>
      <p class="section-intro">{{ site.postsIntro.text }}</p>
    </div>
    <div class="posts-list">
      {% for post in collections.posts | reverse %}
        <article class="post-card">
          <p class="post-card-date">{{ post.date | displayDate }}</p>
          <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
          {% if post.data.excerpt %}
            <p class="post-card-excerpt">{{ post.data.excerpt }}</p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </section>
</main>
