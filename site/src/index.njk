---
layout: base.njk
---
<main class="page-shell">
  <section class="hero-stage">
    <div class="hero-copy">
      <h1>{{ site.hero.title }}</h1>
      {% if site.hero.subline %}
        <p class="hero-subline">{{ site.hero.subline }}</p>
      {% endif %}
      <figure class="hero-portrait">
        <img class="profile-image" src="{{ site.profile.image }}" alt="{{ site.profile.imageAlt }}" title="mario">
      </figure>
      <nav class="hero-links" aria-label="Profile links">
        {% for link in site.links %}
          <a class="hero-link" href="{{ link.url }}" target="_blank" rel="noreferrer" aria-label="{{ link.label or (link.name | lower) }}" title="{{ link.label or (link.name | lower) }}">
            <span>{{ link.label or (link.name | lower) }}</span>
          </a>
        {% endfor %}
      </nav>
    </div>
  </section>

  <section class="posts-section">
    <div class="posts-layout">
      <div class="posts-list">
        {% for post in collections.posts | reverse %}
          <article class="post-card">
            <a class="post-link" href="{{ post.url }}">
              <p class="post-card-date">{{ post.date | displayDate }}</p>
              <div class="post-card-body">
                <h2>{{ post.data.title }}</h2>
                {% if post.data.excerpt %}
                  <p class="post-card-excerpt">{{ post.data.excerpt }}</p>
                {% endif %}
              </div>
            </a>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>
</main>
