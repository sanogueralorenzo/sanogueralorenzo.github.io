---
layout: base.njk
---
<main class="unmade-page unmade-entry-page">
  <nav class="unmade-topbar" aria-label="Unmade navigation">
    <a class="unmade-wordmark" href="/unmade/">Unmade</a>
    <a class="unmade-home-link" href="/">Mario</a>
  </nav>

  <article class="unmade-case">
    <header class="unmade-case-header">
      <p class="unmade-kicker">{{ category }} / {{ status }}</p>
      <h1>{{ title }}</h1>
      <p>{{ excerpt }}</p>
    </header>

    <div class="unmade-case-grid">
      <section class="unmade-evidence" aria-label="Visual trace">
        <div class="unmade-object unmade-object-{{ visual }}">
          <span>{{ mark }}</span>
        </div>
      </section>

      <section class="unmade-case-notes">
        <dl>
          <div>
            <dt>Category</dt>
            <dd>{{ category }}</dd>
          </div>
          <div>
            <dt>State</dt>
            <dd>{{ status }}</dd>
          </div>
          <div>
            <dt>Trace</dt>
            <dd>{{ trace }}</dd>
          </div>
          <div>
            <dt>Question</dt>
            <dd>{{ question }}</dd>
          </div>
        </dl>
      </section>
    </div>

    <section class="unmade-case-body prose">
      {{ content | safe }}
    </section>
  </article>
</main>
