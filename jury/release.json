{
  "schema_version": "jury.release.v1",
  "name": "@sanogueralorenzo/jury",
  "version": "0.1.0",
  "status": "prototype-v1",
  "cli": {
    "entrypoint": "bin/jury.mjs",
    "node": ">=20",
    "commands": [
      "init",
      "claim create",
      "claim transition",
      "check add",
      "check update",
      "evidence add",
      "critic run",
      "objection add",
      "objection resolve",
      "waiver add",
      "status",
      "judge",
      "gate",
      "bundle export",
      "bundle preflight",
      "bundle import",
      "check",
      "demo code-change"
    ]
  },
  "state": {
    "defaultDir": ".jury",
    "format": "append-only jsonl",
    "files": [
      "claims.jsonl",
      "checks.jsonl",
      "evidence.jsonl",
      "objections.jsonl",
      "waivers.jsonl",
      "verdicts.jsonl"
    ]
  },
  "schemas": {
    "claim": "schemas/claim.schema.json",
    "check": "schemas/check.schema.json",
    "evidence": "schemas/evidence.schema.json",
    "keyPolicy": "schemas/key-policy.schema.json",
    "objection": "schemas/objection.schema.json",
    "packageReleaseArchiveManifest": "schemas/package-release-archive-manifest.schema.json",
    "packageReleaseEvidence": "schemas/package-release-evidence.schema.json",
    "packageReleaseRemediationAudit": "schemas/package-release-remediation-audit.schema.json",
    "packageReleaseRemediationAuditHandoff": "schemas/package-release-remediation-audit-handoff.schema.json",
    "reviewBundle": "schemas/review-bundle.schema.json",
    "waiver": "schemas/waiver.schema.json",
    "verdict": "schemas/verdict.schema.json"
  },
  "exports": {
    "check": "examples/exports/check.passed.v1.json",
    "reviewBundle": "examples/exports/review-bundle.accept.v1.json",
    "verdict": "examples/exports/verdict.accept.v1.json"
  },
  "ciAdoption": {
    "guide": "CI_ADOPTION.md",
    "workflows": [
      {
        "variant": "unsigned-single-job",
        "path": "examples/ci/jury-review-gate.yml",
        "trustBoundary": "single-job",
        "artifacts": [
          "verdict.json",
          "gate.json",
          "review-bundle.json",
          ".jury/*.jsonl"
        ]
      },
      {
        "variant": "signed-producer",
        "path": "examples/ci/jury-signed-review-gate.yml",
        "trustBoundary": "signed producer output",
        "artifacts": [
          "verdict.json",
          "gate.json",
          "review-bundle.signed.json",
          ".jury/*.jsonl"
        ]
      },
      {
        "variant": "signed-artifact-handoff",
        "path": "examples/ci/jury-signed-artifact-handoff.yml",
        "trustBoundary": "downloaded producer artifact",
        "artifacts": [
          "verdict.json",
          "gate.json",
          "review-bundle.signed.json",
          ".jury/*.jsonl",
          "downstream-verdict.json",
          "downstream-gate.json",
          ".jury-downstream/*.jsonl"
        ]
      },
      {
        "variant": "reusable-downstream-verifier",
        "path": "examples/ci/jury-trusted-bundle-verify.yml",
        "trustBoundary": "reusable trusted-producer verification",
        "artifacts": [
          "imported-verdict.json",
          "trusted-gate.json",
          ".jury-trusted/*.jsonl"
        ]
      },
      {
        "variant": "reusable-code-change-adoption",
        "path": "examples/ci/jury-code-change-adoption.yml",
        "trustBoundary": "signed reusable code-change fixture artifact publication",
        "artifacts": [
          "verdict.retry.json",
          "gate.retry.json",
          "review-bundle.retry.json",
          "review-bundle.retry.signed.json",
          "verdict.accept.json",
          "gate.accept.json",
          "review-bundle.accept.json",
          "review-bundle.accept.signed.json",
          "${{ inputs.state-dir }}/*.jsonl"
        ]
      }
    ]
  },
  "packagePublication": {
    "notes": "PUBLISHING.md",
    "workflow": "examples/ci/jury-package-manifest-check.yml",
    "releaseWorkflow": "examples/ci/jury-npm-publish.yml",
    "manifestCheckCommand": "npm --prefix jury run package:manifest:check",
    "packDryRunCommand": "cd jury && npm pack --dry-run --json",
    "requiredFiles": [
      "package.json",
      "PUBLISHING.md",
      "release.json",
      "CI_ADOPTION.md",
      "MIGRATION.md",
      "README.md",
      "bin/jury.mjs",
      "scripts/check-package-manifest.mjs",
      "scripts/validate-package-release-fixtures.mjs",
      "schemas",
      "examples/ci/jury-package-manifest-check.yml",
      "examples/ci/jury-npm-publish.yml",
      "examples/ci/jury-review-gate.yml",
      "examples/ci/jury-signed-review-gate.yml",
      "examples/ci/jury-signed-artifact-handoff.yml",
      "examples/ci/jury-trusted-bundle-verify.yml",
      "examples/ci/jury-code-change-adoption.yml",
      "examples/code-change-adoption",
      "examples/ci/fixtures/key-policy",
      "examples/ci/fixtures/package-release"
    ]
  },
  "ciArtifacts": [
    "verdict.json",
    "gate.json",
    "review-bundle.json",
    "jury-demo-transcript.json",
    ".jury/*.jsonl"
  ]
}
