{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jury Key Policy",
  "type": "object",
  "required": ["schema_version", "producers"],
  "properties": {
    "schema_version": { "const": "jury.key_policy.v1" },
    "producers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "keys"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "revision_pattern": { "type": "string", "minLength": 1 },
          "keys": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["key_id", "type"],
              "properties": {
                "key_id": { "type": "string", "minLength": 1 },
                "type": { "const": "rsa-sha256" },
                "public_key": { "type": "string", "minLength": 1 },
                "public_key_path": { "type": "string", "minLength": 1 }
              },
              "oneOf": [
                { "required": ["public_key"] },
                { "required": ["public_key_path"] }
              ],
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
