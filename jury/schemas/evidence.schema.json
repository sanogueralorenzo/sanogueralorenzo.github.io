{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jury Evidence",
  "type": "object",
  "required": ["schema_version", "id", "claim_id", "type", "summary", "source", "status", "collected_at"],
  "properties": {
    "schema_version": { "const": "jury.evidence.v1" },
    "id": { "type": "string", "minLength": 1 },
    "claim_id": { "type": "string", "minLength": 1 },
    "type": { "enum": ["command", "diff", "artifact", "citation", "screenshot", "log", "review", "manual", "approval", "tool_call_preview", "policy_check"] },
    "summary": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "status": { "enum": ["pending", "passed", "failed", "inconclusive"] },
    "command": { "type": ["string", "null"] },
    "exit_code": { "type": ["integer", "null"] },
    "collected_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
