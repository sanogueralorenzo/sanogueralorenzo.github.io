{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jury Objection",
  "type": "object",
  "required": ["schema_version", "id", "claim_id", "summary", "raised_by", "severity", "status", "evidence_ids", "created_at", "updated_at"],
  "properties": {
    "schema_version": { "const": "jury.objection.v1" },
    "id": { "type": "string", "minLength": 1 },
    "claim_id": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "raised_by": { "type": "string", "minLength": 1 },
    "severity": { "enum": ["low", "medium", "high", "critical"] },
    "status": { "enum": ["open", "resolved", "waived", "rejected"] },
    "evidence_ids": { "type": "array", "items": { "type": "string" } },
    "resolution": { "type": ["string", "null"] },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
