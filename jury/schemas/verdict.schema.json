{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jury Verdict",
  "type": "object",
  "required": ["schema_version", "id", "claim_id", "claim_version", "decision", "reason", "evidence_ids", "objection_ids", "waiver_ids", "decided_by", "decided_at"],
  "properties": {
    "schema_version": { "const": "jury.verdict.v1" },
    "id": { "type": "string", "minLength": 1 },
    "claim_id": { "type": "string", "minLength": 1 },
    "claim_version": { "type": "integer", "minimum": 1 },
    "decision": { "enum": ["accept", "reject", "retry", "human_decision"] },
    "reason": { "type": "string", "minLength": 1 },
    "next_actions": { "type": "array", "items": { "type": "string" } },
    "evidence_ids": { "type": "array", "items": { "type": "string" } },
    "objection_ids": { "type": "array", "items": { "type": "string" } },
    "waiver_ids": { "type": "array", "items": { "type": "string" } },
    "check_ids": { "type": "array", "items": { "type": "string" } },
    "decided_by": { "type": "string", "minLength": 1 },
    "decided_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
