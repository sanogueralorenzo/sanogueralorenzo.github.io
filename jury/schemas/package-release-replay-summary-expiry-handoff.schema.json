{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jury Package Release Replay Summary Expiry Handoff",
  "type": "object",
  "required": [
    "schema_version",
    "reason",
    "sourceArtifact",
    "expiredAfterDays",
    "reconstructedSummary",
    "reconstructedFrom",
    "failedPackageVersion",
    "replacementPackageVersion",
    "reviewedBy"
  ],
  "properties": {
    "schema_version": { "const": "jury.package_release_replay_summary_expiry_handoff.v1" },
    "reason": { "const": "jury-package-release-replay-summary artifact expired before promotion" },
    "sourceArtifact": { "const": "jury-package-release-replay-summary" },
    "expiredAfterDays": { "const": 90 },
    "reconstructedSummary": { "const": "jury-package-release-replay-summary.md" },
    "reconstructedFrom": {
      "type": "array",
      "minItems": 2,
      "allOf": [
        { "contains": { "const": "retained-package-release-evidence-manifest.json" } },
        { "contains": { "const": "archive-drift-remediation-audit.json" } }
      ],
      "items": { "type": "string", "minLength": 1 }
    },
    "failedPackageVersion": { "type": "string", "minLength": 1 },
    "replacementPackageVersion": { "type": "string", "minLength": 1 },
    "reviewedBy": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
