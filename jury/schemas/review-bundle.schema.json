{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jury Review Bundle",
  "type": "object",
  "required": ["schema_version", "exported_at", "claim_id", "producer", "provenance", "records"],
  "properties": {
    "schema_version": { "const": "jury.review_bundle.v1" },
    "exported_at": { "type": "string", "minLength": 1 },
    "claim_id": { "type": "string", "minLength": 1 },
    "producer": {
      "type": "object",
      "required": ["name", "version", "command"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "required": ["source", "revision", "workflow", "run_id"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "revision": { "type": "string", "minLength": 1 },
        "workflow": { "type": ["string", "null"] },
        "run_id": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "attestation": {
      "type": "object",
      "required": ["type", "key_id", "signed_at", "signature"],
      "properties": {
        "type": { "enum": ["hmac-sha256", "rsa-sha256"] },
        "key_id": { "type": "string", "minLength": 1 },
        "signed_at": { "type": "string", "format": "date-time", "minLength": 1 },
        "signature": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "hmac-sha256" } }, "required": ["type"] },
          "then": { "properties": { "signature": { "pattern": "^[0-9a-f]{64}$" } } }
        },
        {
          "if": { "properties": { "type": { "const": "rsa-sha256" } }, "required": ["type"] },
          "then": { "properties": { "signature": { "pattern": "^[A-Za-z0-9+/]+={0,2}$" } } }
        }
      ],
      "additionalProperties": true
    },
    "records": {
      "type": "object",
      "required": ["claims", "checks", "evidence", "objections", "waivers", "verdicts"],
      "properties": {
        "claims": { "type": "array", "items": { "$ref": "claim.schema.json" } },
        "checks": { "type": "array", "items": { "$ref": "check.schema.json" } },
        "evidence": { "type": "array", "items": { "$ref": "evidence.schema.json" } },
        "objections": { "type": "array", "items": { "$ref": "objection.schema.json" } },
        "waivers": { "type": "array", "items": { "$ref": "waiver.schema.json" } },
        "verdicts": { "type": "array", "items": { "$ref": "verdict.schema.json" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
