{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jury Claim",
  "type": "object",
  "required": ["schema_version", "id", "version", "summary", "claimant", "scope", "impact", "status", "created_at", "updated_at"],
  "properties": {
    "schema_version": { "const": "jury.claim.v1" },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "claimant": { "type": "string", "minLength": 1 },
    "scope": { "type": "array", "items": { "type": "string" } },
    "impact": { "enum": ["low", "medium", "high", "critical"] },
    "status": { "enum": ["draft", "submitted", "screening", "in_review", "revision_required", "ready_for_judgment", "decided", "archived"] },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
