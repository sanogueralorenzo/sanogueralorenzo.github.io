{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jury Package Release Replay Summary Diagnostics Retention Handoff",
  "type": "object",
  "required": [
    "schema_version",
    "reason",
    "sourceArtifact",
    "sourceJob",
    "retentionDays",
    "diagnosticsSchemaVersion",
    "retainedDiagnostics",
    "summaryFile",
    "retainedWith",
    "failedPackageVersion",
    "failedTarballName",
    "replacementPackageVersion",
    "runId",
    "sourceRevision",
    "reviewedBy"
  ],
  "properties": {
    "schema_version": { "const": "jury.package_release_replay_summary_diagnostics_retention_handoff.v1" },
    "reason": { "const": "jury-package-release-replay-summary-diagnostics retained with failed and replacement release archives" },
    "sourceArtifact": { "const": "jury-package-release-replay-summary" },
    "sourceJob": { "const": "package-release-evidence-replay" },
    "retentionDays": { "const": 90 },
    "diagnosticsSchemaVersion": { "const": "jury.package_release_replay_summary_diagnostics.v1" },
    "retainedDiagnostics": { "const": "jury-package-release-replay-summary-diagnostics.json" },
    "summaryFile": { "const": "jury-package-release-replay-summary.md" },
    "retainedWith": {
      "type": "array",
      "minItems": 3,
      "allOf": [
        { "contains": { "const": "retained-package-release-evidence-manifest.json" } },
        { "contains": { "const": "jury-package-release-replay-summary.md" } },
        { "contains": { "const": "archive-drift-remediation-audit.json" } }
      ],
      "items": { "type": "string", "minLength": 1 }
    },
    "failedPackageVersion": { "type": "string", "minLength": 1 },
    "failedTarballName": { "type": "string", "pattern": "\\.tgz$" },
    "replacementPackageVersion": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "sourceRevision": { "type": "string", "minLength": 1 },
    "reviewedBy": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
