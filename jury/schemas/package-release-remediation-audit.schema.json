{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jury Package Release Remediation Audit",
  "type": "object",
  "required": ["schema_version", "audit_type", "package", "failed", "replacement", "drift", "remediation", "verification", "approval", "record"],
  "properties": {
    "schema_version": { "const": "jury.package_release_remediation_audit.v1" },
    "audit_type": { "const": "retained-archive-drift-remediation" },
    "package": { "type": "string", "minLength": 1 },
    "failed": {
      "type": "object",
      "required": ["packageVersion", "tarballName", "archiveEvidence"],
      "properties": {
        "packageVersion": { "type": "string", "minLength": 1 },
        "tarballName": { "type": "string", "pattern": "\\.tgz$" },
        "archiveEvidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "replacement": {
      "type": "object",
      "required": ["packageVersion", "archiveEvidence"],
      "properties": {
        "packageVersion": { "type": "string", "minLength": 1 },
        "archiveEvidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "drift": {
      "type": "object",
      "required": ["detectedBy", "manifest", "evidence"],
      "properties": {
        "detectedBy": { "const": "fixtures:package-release:drift" },
        "manifest": { "const": "retained-package-release-evidence-manifest.json" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "archive", "failure", "remediation"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "archive": { "enum": ["failed-publication", "replacement-patch", "dry-run"] },
              "failure": { "type": "string", "minLength": 1 },
              "remediation": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "remediation": {
      "type": "object",
      "required": ["policy", "restoredEvidence", "regeneratedManifest", "diffReviewed"],
      "properties": {
        "policy": { "const": "restore-before-regenerate" },
        "restoredEvidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "archive", "source"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "archive": { "enum": ["failed-publication", "replacement-patch", "dry-run"] },
              "source": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "regeneratedManifest": { "const": "retained-package-release-evidence-manifest.json" },
        "diffReviewed": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "required": ["commands"],
      "properties": {
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "approval": {
      "type": "object",
      "required": ["approvedBy", "approvedAt"],
      "properties": {
        "approvedBy": { "type": "string", "minLength": 1 },
        "approvedAt": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "record": {
      "type": "object",
      "required": ["location", "summary"],
      "properties": {
        "location": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
