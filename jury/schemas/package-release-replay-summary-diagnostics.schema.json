{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jury Package Release Replay Summary Diagnostics",
  "type": "object",
  "required": [
    "schema_version",
    "sourceJob",
    "summaryArtifact",
    "summaryFile",
    "failedPackageVersion",
    "failedTarballName",
    "replacementPackageVersion",
    "failedArchiveEvidence",
    "replacementArchiveEvidence",
    "remediationApprovedBy",
    "checkedLines"
  ],
  "properties": {
    "schema_version": { "const": "jury.package_release_replay_summary_diagnostics.v1" },
    "sourceJob": { "const": "package-release-evidence-replay" },
    "summaryArtifact": { "const": "jury-package-release-replay-summary" },
    "summaryFile": { "const": "jury-package-release-replay-summary.md" },
    "failedPackageVersion": { "type": "string", "minLength": 1 },
    "failedTarballName": { "type": "string", "minLength": 1 },
    "replacementPackageVersion": { "type": "string", "minLength": 1 },
    "failedArchiveEvidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "replacementArchiveEvidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "remediationApprovedBy": { "type": "string", "minLength": 1 },
    "checkedLines": {
      "type": "array",
      "minItems": 7,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
