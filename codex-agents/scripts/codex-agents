#!/usr/bin/env bash
set -euo pipefail

STATE_HOME="${CODEX_AGENTS_HOME:-$HOME/.codex/agents}"
TASKS_DIR="$STATE_HOME/tasks"
CONFIG_FILE="$STATE_HOME/config.env"
DEFAULT_WORKER_INTERVAL_SECONDS=30

COMMAND_NAMES=()
COMMAND_USAGES=()
COMMAND_DESCRIPTIONS=()
COMMAND_HANDLERS=()

register_command() {
  local name="$1"
  local usage="$2"
  local description="$3"
  local handler="$4"

  if [[ -z "$name" || -z "$usage" || -z "$description" || -z "$handler" ]]; then
    echo "Internal error: invalid command registration." >&2
    exit 1
  fi

  if command_index_by_name "$name" >/dev/null; then
    echo "Internal error: duplicated command registration '$name'." >&2
    exit 1
  fi

  COMMAND_NAMES+=("$name")
  COMMAND_USAGES+=("$usage")
  COMMAND_DESCRIPTIONS+=("$description")
  COMMAND_HANDLERS+=("$handler")
}

command_index_by_name() {
  local target="$1"
  local i
  for (( i=0; i<${#COMMAND_NAMES[@]}; i++ )); do
    if [[ "${COMMAND_NAMES[$i]}" == "$target" ]]; then
      echo "$i"
      return 0
    fi
  done
  return 1
}

init_command_registry() {
  register_command "config" "config init" "Initialize local codex-agents configuration." "command_config"
  register_command "task" "task create|list|show ..." "Create/list/show tasks." "command_task"
  register_command "worker" "worker start [--once] [--interval-seconds N]" "Start autonomous worker loop." "command_worker"
  register_command "help" "help" "Print this help output." "command_help"
}

print_usage() {
  local max_len=0
  local i
  for (( i=0; i<${#COMMAND_NAMES[@]}; i++ )); do
    if (( ${#COMMAND_NAMES[$i]} > max_len )); then
      max_len=${#COMMAND_NAMES[$i]}
    fi
  done

  echo "Usage:"
  for (( i=0; i<${#COMMAND_NAMES[@]}; i++ )); do
    echo "  codex-agents ${COMMAND_USAGES[$i]}"
  done
  echo
  echo "Commands:"
  for (( i=0; i<${#COMMAND_NAMES[@]}; i++ )); do
    printf "  %-*s  %s\n" "$max_len" "${COMMAND_NAMES[$i]}" "${COMMAND_DESCRIPTIONS[$i]}"
  done
}

print_command_help_by_index() {
  local index="$1"
  local name="${COMMAND_NAMES[$index]}"
  local usage="${COMMAND_USAGES[$index]}"
  local description="${COMMAND_DESCRIPTIONS[$index]}"

  echo "Usage:"
  echo "  codex-agents $usage"
  echo
  echo "Description:"
  echo "  $description"

  case "$name" in
    config)
      echo
      echo "Subcommands:"
      echo "  init  Initialize local codex-agents configuration."
      ;;
    task)
      echo
      echo "Subcommands:"
      echo "  create <TICKET-KEY>  Create task from ticket key."
      echo "  list                 List tracked tasks."
      echo "  show <TICKET-KEY>    Show task details by ticket key."
      ;;
    worker)
      echo
      echo "Subcommands:"
      echo "  start  Start autonomous worker loop."
      echo
      echo "Options:"
      echo "  --once                 Run exactly one worker cycle and exit."
      echo "  --interval-seconds N   Polling interval for worker loop (default: ${DEFAULT_WORKER_INTERVAL_SECONDS})."
      ;;
  esac
}

print_command_help_by_name() {
  local name="$1"
  local index
  if ! index="$(command_index_by_name "$name")"; then
    echo "Unknown command: $name" >&2
    print_usage >&2
    exit 1
  fi
  print_command_help_by_index "$index"
}

print_usage_and_description() {
  local usage="$1"
  local description="$2"
  echo "Usage:"
  echo "  $usage"
  echo
  echo "Description:"
  echo "  $description"
}

now_utc() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

ensure_state_layout() {
  mkdir -p "$TASKS_DIR"
  if [[ ! -f "$CONFIG_FILE" ]]; then
    cat > "$CONFIG_FILE" <<EOF
state_version=1
initialized_at=$(now_utc)
EOF
  fi
}

validate_ticket_key() {
  local ticket="$1"
  if [[ ! "$ticket" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "Invalid ticket key: $ticket" >&2
    echo "Allowed characters: letters, numbers, dot, underscore, hyphen." >&2
    exit 1
  fi
}

task_path() {
  local ticket="$1"
  echo "$TASKS_DIR/${ticket}.task"
}

task_field() {
  local file="$1"
  local key="$2"
  awk -F= -v key="$key" '$1 == key { print substr($0, index($0, "=") + 1); exit }' "$file"
}

task_exists() {
  local ticket="$1"
  [[ -f "$(task_path "$ticket")" ]]
}

write_task_file() {
  local ticket="$1"
  local status="$2"
  local created_at="$3"
  local updated_at="$4"
  local file
  file="$(task_path "$ticket")"

  cat > "$file" <<EOF
ticket=$ticket
status=$status
created_at=$created_at
updated_at=$updated_at
EOF
}

task_create() {
  local ticket="$1"
  validate_ticket_key "$ticket"
  ensure_state_layout

  if task_exists "$ticket"; then
    echo "Task already exists: $ticket" >&2
    exit 1
  fi

  local now
  now="$(now_utc)"
  write_task_file "$ticket" "pending" "$now" "$now"
  echo "Created task: $ticket"
}

task_list() {
  ensure_state_layout
  shopt -s nullglob
  local task_files=("$TASKS_DIR"/*.task)
  shopt -u nullglob

  if [[ "${#task_files[@]}" -eq 0 ]]; then
    echo "No tasks found."
    return
  fi

  printf "%-24s %-10s %s\n" "TICKET" "STATUS" "UPDATED_AT"
  for file in "${task_files[@]}"; do
    local ticket
    local status
    local updated_at
    ticket="$(task_field "$file" "ticket")"
    status="$(task_field "$file" "status")"
    updated_at="$(task_field "$file" "updated_at")"
    printf "%s\t%s\t%s\n" "$ticket" "$status" "$updated_at"
  done | sort -t $'\t' -k3,3r | while IFS=$'\t' read -r ticket status updated_at; do
    printf "%-24s %-10s %s\n" "$ticket" "$status" "$updated_at"
  done
}

task_show() {
  local ticket="$1"
  validate_ticket_key "$ticket"
  ensure_state_layout
  local file
  file="$(task_path "$ticket")"

  if [[ ! -f "$file" ]]; then
    echo "Task not found: $ticket" >&2
    exit 1
  fi

  echo "ticket: $(task_field "$file" "ticket")"
  echo "status: $(task_field "$file" "status")"
  echo "created_at: $(task_field "$file" "created_at")"
  echo "updated_at: $(task_field "$file" "updated_at")"
  echo "path: $file"
}

pick_next_pending_task() {
  shopt -s nullglob
  local task_files=("$TASKS_DIR"/*.task)
  shopt -u nullglob

  if [[ "${#task_files[@]}" -eq 0 ]]; then
    return 1
  fi

  local pending_rows=()
  local file
  for file in "${task_files[@]}"; do
    local ticket
    local status
    local created_at
    local updated_at
    ticket="$(task_field "$file" "ticket")"
    status="$(task_field "$file" "status")"
    created_at="$(task_field "$file" "created_at")"
    updated_at="$(task_field "$file" "updated_at")"
    if [[ "$status" == "pending" || "$status" == "open" ]]; then
      pending_rows+=("${updated_at}|${ticket}|${created_at}")
    fi
  done

  if [[ "${#pending_rows[@]}" -eq 0 ]]; then
    return 1
  fi

  printf "%s\n" "${pending_rows[@]}" | sort | head -n1
}

run_worker_cycle() {
  local timestamp
  timestamp="$(now_utc)"
  local selection
  if ! selection="$(pick_next_pending_task)"; then
    echo "[$timestamp] No pending tasks."
    return
  fi

  local updated_at
  local ticket
  local created_at
  IFS='|' read -r updated_at ticket created_at <<< "$selection"
  echo "[$timestamp] Next pending task: $ticket (created $created_at, updated $updated_at)"
  echo "[$timestamp] Suggested next step: codex-agents task show $ticket"
}

print_task_subcommand_help() {
  local subcommand="$1"
  case "$subcommand" in
    create)
      print_usage_and_description "codex-agents task create <TICKET-KEY>" "Create task from ticket key."
      ;;
    list)
      print_usage_and_description "codex-agents task list" "List tracked tasks."
      ;;
    show)
      print_usage_and_description "codex-agents task show <TICKET-KEY>" "Show task details by ticket key."
      ;;
    *)
      echo "Unknown task command: $subcommand" >&2
      exit 1
      ;;
  esac
}

command_help() {
  if [[ "$#" -eq 0 ]]; then
    print_usage
    return
  fi
  if [[ "$#" -eq 1 ]]; then
    print_command_help_by_name "$1"
    return
  fi
  echo "Unexpected arguments for help: $*" >&2
  exit 1
}

command_config() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    if [[ "$#" -gt 1 ]]; then
      echo "Unexpected arguments for config --help: ${*:2}" >&2
      exit 1
    fi
    print_command_help_by_name "config"
    return
  fi

  if [[ "${1:-}" == "init" ]]; then
    if [[ "${2:-}" == "--help" || "${2:-}" == "-h" ]]; then
      if [[ "$#" -gt 2 ]]; then
        echo "Unexpected arguments for config init --help: ${*:3}" >&2
        exit 1
      fi
      print_usage_and_description "codex-agents config init" "Initialize local codex-agents configuration."
      return
    fi
    if [[ "$#" -gt 1 ]]; then
      echo "Unexpected arguments for config init: ${*:2}" >&2
      exit 1
    fi
    local is_fresh="false"
    if [[ ! -f "$CONFIG_FILE" ]]; then
      is_fresh="true"
    fi
    ensure_state_layout
    if [[ "$is_fresh" == "true" ]]; then
      echo "Initialized codex-agents state at: $STATE_HOME"
    else
      echo "codex-agents state already initialized at: $STATE_HOME"
    fi
    return
  fi

  echo "Unknown config command. Run: codex-agents help" >&2
  exit 1
}

command_task() {
  local subcommand="${1:-}"
  if [[ "$subcommand" == "--help" || "$subcommand" == "-h" ]]; then
    if [[ "$#" -gt 1 ]]; then
      echo "Unexpected arguments for task --help: ${*:2}" >&2
      exit 1
    fi
    print_command_help_by_name "task"
    return
  fi
  case "$subcommand" in
    create)
      if [[ "${2:-}" == "--help" || "${2:-}" == "-h" ]]; then
        if [[ "$#" -gt 2 ]]; then
          echo "Unexpected arguments for task create --help: ${*:3}" >&2
          exit 1
        fi
        print_task_subcommand_help "create"
        return
      fi
      if [[ -z "${2:-}" ]]; then
        echo "Missing ticket key. Example: codex-agents task create TS-1234" >&2
        exit 1
      fi
      if [[ "$#" -gt 2 ]]; then
        echo "Unexpected arguments for task create: ${*:3}" >&2
        exit 1
      fi
      task_create "$2"
      return
      ;;
    list)
      if [[ "${2:-}" == "--help" || "${2:-}" == "-h" ]]; then
        if [[ "$#" -gt 2 ]]; then
          echo "Unexpected arguments for task list --help: ${*:3}" >&2
          exit 1
        fi
        print_task_subcommand_help "list"
        return
      fi
      if [[ "$#" -gt 1 ]]; then
        echo "Unexpected arguments for task list: ${*:2}" >&2
        exit 1
      fi
      task_list
      return
      ;;
    show)
      if [[ "${2:-}" == "--help" || "${2:-}" == "-h" ]]; then
        if [[ "$#" -gt 2 ]]; then
          echo "Unexpected arguments for task show --help: ${*:3}" >&2
          exit 1
        fi
        print_task_subcommand_help "show"
        return
      fi
      if [[ -z "${2:-}" ]]; then
        echo "Missing ticket key. Example: codex-agents task show TS-1234" >&2
        exit 1
      fi
      if [[ "$#" -gt 2 ]]; then
        echo "Unexpected arguments for task show: ${*:3}" >&2
        exit 1
      fi
      task_show "$2"
      return
      ;;
    *)
      echo "Unknown task command. Run: codex-agents help" >&2
      exit 1
      ;;
  esac
}

command_worker() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    if [[ "$#" -gt 1 ]]; then
      echo "Unexpected arguments for worker --help: ${*:2}" >&2
      exit 1
    fi
    print_command_help_by_name "worker"
    return
  fi

  if [[ "${1:-}" == "start" ]]; then
    shift
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      if [[ "$#" -gt 1 ]]; then
        echo "Unexpected arguments for worker start --help: ${*:2}" >&2
        exit 1
      fi
      print_usage_and_description "codex-agents worker start [--once] [--interval-seconds N]" "Start autonomous worker loop."
      return
    fi

    local interval_seconds="$DEFAULT_WORKER_INTERVAL_SECONDS"
    local run_once="false"

    while [[ "$#" -gt 0 ]]; do
      case "$1" in
        --once)
          run_once="true"
          shift
          ;;
        --interval-seconds)
          if [[ "$#" -lt 2 ]]; then
            echo "Missing value for --interval-seconds" >&2
            exit 1
          fi
          if [[ ! "$2" =~ ^[0-9]+$ ]] || [[ "$2" -le 0 ]]; then
            echo "Invalid --interval-seconds value: $2" >&2
            exit 1
          fi
          interval_seconds="$2"
          shift 2
          ;;
        *)
          echo "Unexpected arguments for worker start: $*" >&2
          exit 1
          ;;
      esac
    done

    ensure_state_layout
    if [[ "$run_once" == "true" ]]; then
      run_worker_cycle
      return
    fi

    trap 'echo "Worker stopped."; exit 0' INT TERM
    echo "Worker started (interval: ${interval_seconds}s). Press Ctrl+C to stop."
    while true; do
      run_worker_cycle
      sleep "$interval_seconds"
    done
  fi

  echo "Unknown worker command. Run: codex-agents help" >&2
  exit 1
}

dispatch_command() {
  local command="$1"
  shift

  if [[ "$command" == "--help" || "$command" == "-h" ]]; then
    command="help"
  fi

  if [[ "$command" != "help" ]]; then
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      shift
      if [[ "$#" -gt 0 ]]; then
        echo "Unexpected arguments for $command --help: $*" >&2
        exit 1
      fi
      print_command_help_by_name "$command"
      return
    fi
  fi

  local index
  if ! index="$(command_index_by_name "$command")"; then
    echo "Unknown command: $command" >&2
    print_usage >&2
    exit 1
  fi

  local handler="${COMMAND_HANDLERS[$index]}"
  if ! declare -F "$handler" >/dev/null 2>&1; then
    echo "Internal error: handler '$handler' is not implemented for command '$command'." >&2
    exit 1
  fi

  "$handler" "$@"
}

main() {
  init_command_registry

  local command="help"
  if [[ "$#" -gt 0 ]]; then
    command="$1"
    shift
  fi

  dispatch_command "$command" "$@"
}

main "$@"
