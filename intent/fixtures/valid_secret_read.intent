package fixtures.valid_secret_read

type SecretHandle = {
  name: String
}

goal "read granted secret" {
  capability secret {
    read name: "GITHUB_TOKEN"
  }

  memory session {
    retain summaries until goal_complete
    retain evidence until 30d
  }

  plan {
    step read_github_token -> SecretHandle {
      effect SecretRead(name: "GITHUB_TOKEN")
    }
  }

  verify {
    require no_policy_violations
  }

  invariant {
    deny secret_write
    deny unrelated_secret_read
  }
}
