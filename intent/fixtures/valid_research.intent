package fixtures.research

type Source = {
  url: Url
}

type SourceSet = {
  sources: List<Source>
}

type Claim = {
  text: String
}

type ClaimSet = {
  claims: List<Claim>
}

type ResearchReport = {
  answer: String,
  sources: SourceSet
}

goal "answer research question" {
  context web("https://example.com/**")
  context documents("./docs/**")

  capability web {
    read domain: "example.com"
  }

  capability file {
    read path: "./docs/**"
  }

  memory session {
    retain summaries until goal_complete
    retain evidence until 30d
  }

  plan {
    step collect_sources -> SourceSet
    step extract_claims(input: SourceSet) -> ClaimSet
    step synthesize_answer(input: ClaimSet) -> ResearchReport {
      memory cite session.evidence
    }
  }

  verify {
    require all_outputs_cited
    require no_policy_violations
  }

  invariant {
    deny uncited_external_claim
    deny untrusted_content_to_shell
  }
}
