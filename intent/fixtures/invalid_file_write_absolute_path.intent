package fixtures.invalid_file_write_absolute_path

type Patch = {
  files: List<Path>
}

goal "write absolute path" {
  context repo("./")

  capability file {
    write path: "/**"
  }

  memory session {
    retain summaries until goal_complete
  }

  plan {
    step patch_code -> Patch {
      effect FileWrite(path: "/etc/passwd")
    }
  }

  verify {
    require no_policy_violations
  }
}
