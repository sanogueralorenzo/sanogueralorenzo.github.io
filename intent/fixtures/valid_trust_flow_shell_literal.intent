package fixtures.valid_trust_flow_shell_literal

type Finding = {
  summary: String
}

type ShellResult = {
  exit_code: Int
}

goal "run declared literal command" {
  context repo("./")

  capability shell {
    run command: "npm test"
  }

  memory session {
    retain summaries until goal_complete
    retain evidence until 30d
  }

  plan {
    step inspect_request -> Finding
    step run_tests(input: Finding) -> ShellResult {
      effect ShellExec(command: "npm test")
    }
  }

  verify {
    require shell("npm test").exit_code == 0
  }

  invariant {
    deny untrusted_content_to_shell
  }
}
