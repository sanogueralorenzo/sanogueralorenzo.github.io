package fixtures.memory_flow_graph

type Finding = {
  summary: String
}

type Report = {
  body: String
}

goal memory_flow() -> Report {
  context repo("./")

  memory session {
    retain summaries until goal_complete
    retain evidence until 30d
  }

  plan {
    step inspect -> Finding {
      memory write session.evidence
    }
    step draft(input: Finding) -> Report {
      memory read session.evidence
      memory cite session.evidence
    }
  }

  verify {
    require memory_provenance_complete
  }

  invariant {
    deny secret_write
  }
}
