package fixtures.step_approval_graph

type Finding = {
  summary: String
}

type Patch = {
  files: List<Path>
}

type VerifiedPatch = {
  patch: Patch
}

type GitRef = {
  name: String
}

goal "apply approval gated change" {
  context repo("./")
  context ticket("CODE-654")

  capability file {
    read path: "./src/**"
    read path: "./test/**"
    write path: "./src/**"
    write path: "./test/**"
  }

  capability shell {
    run command: "npm test"
  }

  capability git {
    push branch: "main"
    approval required
  }

  memory session {
    retain approvals until goal_complete
    retain summaries until goal_complete
    retain evidence until 30d
  }

  plan {
    step inspect_request -> Finding
    step patch_code(input: Finding) -> Patch {
      require input.summary != ""
      approval "maintainer approves source patch"
      effect FileWrite(path: "./src/app.ts")
      effect FileWrite(path: "./test/app.test.ts")
      checkpoint "approved patch written"
    }
    step verify_patch(input: Patch) -> VerifiedPatch {
      require input.files != []
      effect ShellExec(command: "npm test")
      checkpoint "tests passed"
    }
    step publish_patch(input: VerifiedPatch) -> GitRef {
      require input.patch.files != []
      approval "maintainer approves main push"
      effect GitPush(branch: "refs/heads/main")
      checkpoint "approved push requested"
    }
  }

  verify {
    require shell("npm test").exit_code == 0
    require no_policy_violations
  }

  invariant {
    deny secret_write
    deny unrelated_file_write
    deny unapproved_sensitive_effect
    deny uncheckpointed_irreversible_effect
  }
}
