package fixtures.invalid_memory_access_undeclared

type Finding = {
  summary: String
}

goal undeclared_memory_access() {
  context repo("./")

  memory session {
    retain summaries until goal_complete
  }

  plan {
    step inspect -> Finding {
      memory read archive.evidence
    }
  }

  verify {
    require memory_provenance_complete
  }

  invariant {
    deny secret_write
  }
}
