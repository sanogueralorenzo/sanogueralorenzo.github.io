package fixtures.invalid_unsupported_goal_statement

type Finding = {
  summary: String
}

goal "reject unsupported goal statement" {
  context repo("./")

  capability file {
    read path: "./src/**"
  }

  memory session {
    retain findings until goal_complete
  }

  delegate reviewer

  plan {
    step inspect_request -> Finding
  }

  verify {
    require Finding.summary != ""
  }

  invariant {
    deny secret_write
  }
}
