{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sanogueralorenzo.github.io/intent/schemas/intent.check.v0.schema.json",
  "title": "Intent Check v0",
  "type": "object",
  "required": ["schema_version", "ok", "diagnostics"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "intent.check.v0"
    },
    "ok": {
      "type": "boolean"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_non_empty_string": {
      "oneOf": [
        {
          "$ref": "#/$defs/non_empty_string"
        },
        {
          "type": "null"
        }
      ]
    },
    "span": {
      "type": "object",
      "required": ["file", "start", "end"],
      "additionalProperties": false,
      "properties": {
        "file": {
          "$ref": "#/$defs/non_empty_string"
        },
        "start": {
          "$ref": "#/$defs/position"
        },
        "end": {
          "$ref": "#/$defs/position"
        }
      }
    },
    "position": {
      "type": "object",
      "required": ["line", "column"],
      "additionalProperties": false,
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        },
        "offset": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "required": ["severity", "code", "message", "span"],
      "properties": {
        "severity": {
          "enum": ["error"]
        },
        "code": {
          "$ref": "#/$defs/non_empty_string"
        },
        "message": {
          "$ref": "#/$defs/non_empty_string"
        },
        "span": {
          "$ref": "#/$defs/span"
        },
        "previous_span": {
          "$ref": "#/$defs/span"
        },
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "type": {
          "$ref": "#/$defs/non_empty_string"
        },
        "step": {
          "$ref": "#/$defs/non_empty_string"
        },
        "parameter": {
          "$ref": "#/$defs/non_empty_string"
        },
        "memory": {
          "$ref": "#/$defs/non_empty_string"
        },
        "scope": {
          "$ref": "#/$defs/non_empty_string"
        },
        "retention": {
          "$ref": "#/$defs/non_empty_string"
        },
        "effect": {
          "$ref": "#/$defs/non_empty_string"
        },
        "family": {
          "$ref": "#/$defs/non_empty_string"
        },
        "action": {
          "$ref": "#/$defs/nullable_non_empty_string"
        },
        "required_family": {
          "$ref": "#/$defs/non_empty_string"
        },
        "declared_capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "argument": {
          "$ref": "#/$defs/non_empty_string"
        },
        "value": {
          "type": "string"
        },
        "allowed": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      },
      "additionalProperties": true
    }
  }
}
