{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sanogueralorenzo.github.io/intent/schemas/intent.graph.v0.schema.json",
  "title": "Intent Graph v0",
  "type": "object",
  "required": [
    "schema_version",
    "ast_schema_version",
    "source",
    "package",
    "ok",
    "diagnostics",
    "nodes",
    "edges"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "intent.graph.v0"
    },
    "ast_schema_version": {
      "const": "intent.ast.v0"
    },
    "source": {
      "$ref": "#/$defs/non_empty_string"
    },
    "package": {
      "$ref": "#/$defs/non_empty_string"
    },
    "ok": {
      "type": "boolean"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "span": {
      "type": "object",
      "required": ["file", "start", "end"],
      "additionalProperties": false,
      "properties": {
        "file": {
          "$ref": "#/$defs/non_empty_string"
        },
        "start": {
          "$ref": "#/$defs/position"
        },
        "end": {
          "$ref": "#/$defs/position"
        }
      }
    },
    "position": {
      "type": "object",
      "required": ["line", "column", "offset"],
      "additionalProperties": false,
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        },
        "offset": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "parameter": {
      "type": "object",
      "required": ["name", "type", "span"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": ["string", "null"]
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "grant": {
      "type": "object",
      "required": ["action", "key", "value", "raw", "span"],
      "additionalProperties": false,
      "properties": {
        "action": {
          "$ref": "#/$defs/non_empty_string"
        },
        "key": {
          "$ref": "#/$defs/non_empty_string"
        },
        "value": {
          "type": "string"
        },
        "raw": {
          "$ref": "#/$defs/non_empty_string"
        },
        "contractId": {
          "$ref": "#/$defs/non_empty_string"
        },
        "contractArgument": {
          "$ref": "#/$defs/non_empty_string"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "retention_rule": {
      "type": "object",
      "required": ["subject", "until", "raw", "span"],
      "additionalProperties": false,
      "properties": {
        "subject": {
          "oneOf": [
            {
              "$ref": "#/$defs/spanned_text"
            },
            {
              "type": "null"
            }
          ]
        },
        "until": {
          "oneOf": [
            {
              "$ref": "#/$defs/spanned_text"
            },
            {
              "type": "null"
            }
          ]
        },
        "raw": {
          "type": "string"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "memory_key": {
      "type": "object",
      "required": ["kind", "name", "type", "typeSpan", "raw", "span"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "MemoryKey"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": ["string", "null"]
        },
        "typeSpan": {
          "oneOf": [
            {
              "$ref": "#/$defs/span"
            },
            {
              "type": "null"
            }
          ]
        },
        "raw": {
          "type": "string"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "spanned_text": {
      "type": "object",
      "required": ["raw", "span"],
      "additionalProperties": false,
      "properties": {
        "raw": {
          "type": "string"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "trust": {
      "type": "object",
      "required": ["zone", "source"],
      "additionalProperties": false,
      "properties": {
        "zone": {
          "enum": ["trusted", "untrusted", "unknown"]
        },
        "source": {
          "$ref": "#/$defs/non_empty_string"
        },
        "argument": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "completion_provenance": {
      "type": "object",
      "required": ["required", "requirements", "invariants", "citations"],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "boolean"
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["requirement", "span"],
            "additionalProperties": false,
            "properties": {
              "requirement": {
                "$ref": "#/$defs/non_empty_string"
              },
              "span": {
                "$ref": "#/$defs/span"
              }
            }
          }
        },
        "invariants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["assertion", "invariant", "span"],
            "additionalProperties": false,
            "properties": {
              "assertion": {
                "enum": ["Require", "Deny"]
              },
              "invariant": {
                "$ref": "#/$defs/non_empty_string"
              },
              "span": {
                "$ref": "#/$defs/span"
              }
            }
          }
        },
        "citations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["memory", "key", "target", "step", "span"],
            "additionalProperties": false,
            "properties": {
              "memory": {
                "$ref": "#/$defs/non_empty_string"
              },
              "key": {
                "type": ["string", "null"]
              },
              "target": {
                "$ref": "#/$defs/non_empty_string"
              },
              "step": {
                "$ref": "#/$defs/non_empty_string"
              },
              "span": {
                "$ref": "#/$defs/span"
              }
            }
          }
        }
      }
    },
    "contract_arguments": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "diagnostic": {
      "type": "object",
      "required": ["severity", "code", "message", "span"],
      "properties": {
        "severity": {
          "enum": ["error"]
        },
        "code": {
          "$ref": "#/$defs/non_empty_string"
        },
        "message": {
          "$ref": "#/$defs/non_empty_string"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      },
      "additionalProperties": true
    },
    "node": {
      "oneOf": [
        {
          "$ref": "#/$defs/type_node"
        },
        {
          "$ref": "#/$defs/goal_node"
        },
        {
          "$ref": "#/$defs/input_node"
        },
        {
          "$ref": "#/$defs/context_node"
        },
        {
          "$ref": "#/$defs/capability_node"
        },
        {
          "$ref": "#/$defs/approval_node"
        },
        {
          "$ref": "#/$defs/policy_node"
        },
        {
          "$ref": "#/$defs/memory_node"
        },
        {
          "$ref": "#/$defs/step_node"
        },
        {
          "$ref": "#/$defs/effect_node"
        },
        {
          "$ref": "#/$defs/completion_node"
        },
        {
          "$ref": "#/$defs/check_node"
        },
        {
          "$ref": "#/$defs/checkpoint_node"
        },
        {
          "$ref": "#/$defs/invariant_node"
        }
      ]
    },
    "base_node": {
      "type": "object",
      "required": ["id", "kind", "label", "span", "data"],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "label": {
          "$ref": "#/$defs/non_empty_string"
        },
        "span": {
          "$ref": "#/$defs/span"
        },
        "data": {
          "type": "object"
        }
      }
    },
    "type_node": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/base_node"
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "Type"
            },
            "data": {
              "type": "object",
              "required": ["definition"],
              "additionalProperties": false,
              "properties": {
                "definition": {
                  "type": ["string", "null"]
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "goal_node": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/base_node"
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "Goal"
            },
            "data": {
              "type": "object",
              "required": ["title", "parameters", "outputType", "outputTypeSpan"],
              "additionalProperties": false,
              "properties": {
                "title": {
                  "type": ["string", "null"]
                },
                "parameters": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/parameter"
                  }
                },
                "outputType": {
                  "type": ["string", "null"]
                },
                "outputTypeSpan": {
                  "oneOf": [
                    {
                      "$ref": "#/$defs/span"
                    },
                    {
                      "type": "null"
                    }
                  ]
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "input_node": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/base_node"
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "Input"
            },
            "data": {
              "type": "object",
              "required": ["scope", "type"],
              "additionalProperties": false,
              "properties": {
                "scope": {
                  "enum": ["goal", "step"]
                },
                "type": {
                  "type": ["string", "null"]
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "context_node": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/base_node"
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "Context"
            },
            "data": {
              "type": "object",
              "required": ["source", "args", "argKinds", "argSpans", "expression", "trust"],
              "additionalProperties": false,
              "properties": {
                "source": {
                  "type": "string"
                },
                "args": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "argKinds": {
                  "type": "object",
                  "additionalProperties": {
                    "enum": ["string", "identifier"]
                  }
                },
                "argSpans": {
                  "type": "object",
                  "additionalProperties": {
                    "$ref": "#/$defs/span"
                  }
                },
                "expression": {
                  "type": "string"
                },
                "contractId": {
                  "$ref": "#/$defs/non_empty_string"
                },
                "contractArguments": {
                  "$ref": "#/$defs/contract_arguments"
                },
                "trust": {
                  "$ref": "#/$defs/trust"
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "capability_node": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/base_node"
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "Capability"
            },
            "data": {
              "type": "object",
              "required": ["family", "action", "grants", "approvalPolicy"],
              "additionalProperties": false,
              "properties": {
                "family": {
                  "type": "string"
                },
                "action": {
                  "type": ["string", "null"]
                },
                "grants": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/grant"
                  }
                },
                "approvalPolicy": {
                  "enum": ["none", "required"]
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "memory_node": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/base_node"
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "Memory"
            },
            "data": {
              "type": "object",
              "required": ["scope", "retention", "retentionRules", "keys"],
              "additionalProperties": false,
              "properties": {
                "scope": {
                  "type": "string"
                },
                "retention": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "retentionRules": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/retention_rule"
                  }
                },
                "keys": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/memory_key"
                  }
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "approval_node": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/base_node"
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "Approval"
            },
            "data": {
              "type": "object",
              "required": ["scope", "ownerStep", "approval"],
              "additionalProperties": false,
              "properties": {
                "scope": {
                  "enum": ["step"]
                },
                "ownerStep": {
                  "type": "string"
                },
                "approval": {
                  "type": "string"
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "policy_node": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/base_node"
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "Policy"
            },
            "data": {
              "type": "object",
              "required": ["scope", "ownerStep", "policyKind", "policy"],
              "additionalProperties": false,
              "properties": {
                "scope": {
                  "enum": ["step"]
                },
                "ownerStep": {
                  "type": "string"
                },
                "policyKind": {
                  "enum": ["timeout", "retry"]
                },
                "policy": {
                  "type": "string"
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "step_node": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/base_node"
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "Step"
            },
            "data": {
              "type": "object",
              "required": ["inputs", "outputType", "outputTypeSpan", "effects", "requirements", "checkpoints", "approvals", "timeouts", "retries", "memoryAccesses"],
              "additionalProperties": false,
              "properties": {
                "inputs": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/parameter"
                  }
                },
                "outputType": {
                  "type": ["string", "null"]
                },
                "outputTypeSpan": {
                  "oneOf": [
                    {
                      "$ref": "#/$defs/span"
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "effects": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "requirements": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "checkpoints": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "approvals": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "timeouts": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "retries": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "memoryAccesses": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/non_empty_string"
                  }
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "effect_node": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/base_node"
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "Effect"
            },
            "data": {
              "type": "object",
              "required": ["family", "action", "args", "argKinds", "argSpans", "trust", "expression", "approvalRequired"],
              "additionalProperties": false,
              "properties": {
                "family": {
                  "type": "string"
                },
                "action": {
                  "type": ["string", "null"]
                },
                "contractId": {
                  "$ref": "#/$defs/non_empty_string"
                },
                "contractArguments": {
                  "$ref": "#/$defs/contract_arguments"
                },
                "args": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "argKinds": {
                  "type": "object",
                  "additionalProperties": {
                    "enum": ["string", "identifier"]
                  }
                },
                "argSpans": {
                  "type": "object",
                  "additionalProperties": {
                    "$ref": "#/$defs/span"
                  }
                },
                "trust": {
                  "$ref": "#/$defs/trust"
                },
                "expression": {
                  "type": "string"
                },
                "approvalRequired": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "completion_node": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/base_node"
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "Completion"
            },
            "data": {
              "type": "object",
              "required": ["outputType", "outputTypeSpan", "provenance"],
              "additionalProperties": false,
              "properties": {
                "outputType": {
                  "type": ["string", "null"]
                },
                "outputTypeSpan": {
                  "oneOf": [
                    {
                      "$ref": "#/$defs/span"
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "provenance": {
                  "$ref": "#/$defs/completion_provenance"
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "check_node": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/base_node"
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "Check"
            },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "scope": {
                  "enum": ["goal", "step"]
                },
                "ownerStep": {
                  "type": "string"
                },
                "assertion": {
                  "enum": ["Require"]
                },
                "requirement": {
                  "type": "string"
                },
                "effect": {
                  "type": "object",
                  "required": ["family", "action", "args", "argKinds", "argSpans", "trust"],
                  "additionalProperties": false,
                  "properties": {
                    "family": {
                      "type": "string"
                    },
                    "action": {
                      "type": ["string", "null"]
                    },
                    "contractId": {
                      "$ref": "#/$defs/non_empty_string"
                    },
                    "contractArguments": {
                      "$ref": "#/$defs/contract_arguments"
                    },
                    "args": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "string"
                      }
                    },
                    "argKinds": {
                      "type": "object",
                      "additionalProperties": {
                        "enum": ["string", "identifier"]
                      }
                    },
                    "argSpans": {
                      "type": "object",
                      "additionalProperties": {
                        "$ref": "#/$defs/span"
                      }
                    },
                    "trust": {
                      "$ref": "#/$defs/trust"
                    }
                  }
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "checkpoint_node": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/base_node"
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "Checkpoint"
            },
            "data": {
              "type": "object",
              "required": ["scope", "ownerStep", "checkpoint"],
              "additionalProperties": false,
              "properties": {
                "scope": {
                  "enum": ["step"]
                },
                "ownerStep": {
                  "type": "string"
                },
                "checkpoint": {
                  "type": "string"
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "invariant_node": {
      "type": "object",
      "allOf": [
        {
          "$ref": "#/$defs/base_node"
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "Invariant"
            },
            "data": {
              "type": "object",
              "required": ["assertion", "invariant"],
              "additionalProperties": false,
              "properties": {
                "assertion": {
                  "enum": ["Require", "Deny"]
                },
                "invariant": {
                  "type": "string"
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["from", "to", "kind"],
      "additionalProperties": false,
      "properties": {
        "from": {
          "$ref": "#/$defs/non_empty_string"
        },
        "to": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kind": {
          "minLength": 1,
          "enum": [
            "authorizes",
            "approves",
            "checkpoints",
            "completes",
            "constrains",
            "data",
            "declares",
            "gates",
            "guards",
            "informs",
            "cites",
            "plans",
            "precedes",
            "produces",
            "reads",
            "requests",
            "requires",
            "retries",
