{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sanogueralorenzo.github.io/intent/schemas/intent.ast.v0.schema.json",
  "title": "Intent AST v0",
  "type": "object",
  "required": ["schema_version", "source", "package", "types", "goals", "span"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "intent.ast.v0"
    },
    "source": {
      "$ref": "#/$defs/non_empty_string"
    },
    "package": {
      "$ref": "#/$defs/package"
    },
    "imports": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/import"
      }
    },
    "types": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/type"
      }
    },
    "goals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/goal"
      }
    },
    "span": {
      "$ref": "#/$defs/span"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_non_empty_string": {
      "oneOf": [
        {
          "$ref": "#/$defs/non_empty_string"
        },
        {
          "type": "null"
        }
      ]
    },
    "span": {
      "type": "object",
      "required": ["file", "start", "end"],
      "additionalProperties": false,
      "properties": {
        "file": {
          "$ref": "#/$defs/non_empty_string"
        },
        "start": {
          "$ref": "#/$defs/position"
        },
        "end": {
          "$ref": "#/$defs/position"
        }
      }
    },
    "position": {
      "type": "object",
      "required": ["line", "column"],
      "additionalProperties": false,
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        },
        "offset": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "parameter": {
      "type": "object",
      "required": ["name", "type", "span"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "type": {
          "$ref": "#/$defs/nullable_non_empty_string"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "package": {
      "type": "object",
      "required": ["kind", "name", "span"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "Package"
        },
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "implicit": {
          "type": "boolean"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "type": {
      "type": "object",
      "required": ["kind", "name", "definition", "span"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "Type"
        },
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "definition": {
          "type": ["string", "null"]
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "import": {
      "type": "object",
      "required": ["kind", "path", "span"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "Import"
        },
        "path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "goal": {
      "type": "object",
      "required": [
        "kind",
        "name",
        "title",
        "parameters",
        "outputType",
        "context",
        "capabilities",
        "memory",
        "steps",
        "verify",
        "invariants",
        "rawBlocks",
        "span"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "Goal"
        },
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "type": ["string", "null"]
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameter"
          }
        },
        "outputType": {
          "$ref": "#/$defs/nullable_non_empty_string"
        },
        "outputTypeSpan": {
          "oneOf": [
            {
              "$ref": "#/$defs/span"
            },
            {
              "type": "null"
            }
          ]
        },
        "context": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/context_source"
          }
        },
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/capability"
          }
        },
        "memory": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/memory"
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/step"
          }
        },
        "verify": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statement"
          }
        },
        "invariants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statement"
          }
        },
        "rawBlocks": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/block"
              },
              {
                "$ref": "#/$defs/statement"
              }
            ]
          }
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "statement": {
      "type": "object",
      "required": ["kind", "value", "span"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "value": {
          "type": "string"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "context_source": {
      "type": "object",
      "required": ["kind", "value", "source", "args", "argKinds", "argSpans", "expression", "trust", "span"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "ContextSource"
        },
        "value": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/non_empty_string"
        },
        "args": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "argKinds": {
          "type": "object",
          "additionalProperties": {
            "enum": ["string", "identifier"]
          }
        },
        "argSpans": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/span"
          }
        },
        "expression": {
          "type": "string"
        },
        "trust": {
          "$ref": "#/$defs/trust"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "trust": {
      "type": "object",
      "required": ["zone", "source"],
      "additionalProperties": false,
      "properties": {
        "zone": {
          "enum": ["trusted", "untrusted", "unknown"]
        },
        "source": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "block": {
      "type": "object",
      "required": ["kind", "name", "header", "span"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "Block"
        },
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "header": {
          "$ref": "#/$defs/non_empty_string"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "capability": {
      "type": "object",
      "required": ["kind", "family", "action", "name", "constraints", "grants", "approvalRequired", "span"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "Capability"
        },
        "family": {
          "$ref": "#/$defs/non_empty_string"
        },
        "action": {
          "$ref": "#/$defs/nullable_non_empty_string"
        },
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "constraints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "grants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/grant"
          }
        },
        "approvalRequired": {
          "type": "boolean"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "grant": {
      "type": "object",
      "required": ["action", "key", "value", "raw", "span"],
      "additionalProperties": false,
      "properties": {
        "action": {
          "$ref": "#/$defs/non_empty_string"
        },
        "key": {
          "$ref": "#/$defs/non_empty_string"
        },
        "value": {
          "type": "string"
        },
        "raw": {
          "$ref": "#/$defs/non_empty_string"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "memory": {
      "type": "object",
      "required": ["kind", "scope", "name", "retention", "retentionRules", "statements", "span"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "Memory"
        },
        "scope": {
          "$ref": "#/$defs/non_empty_string"
        },
        "name": {
          "$ref": "#/$defs/nullable_non_empty_string"
        },
        "retention": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "retentionRules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/retention_rule"
          }
        },
        "statements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "retention_rule": {
      "type": "object",
      "required": ["subject", "until", "raw", "span"],
      "additionalProperties": false,
      "properties": {
        "subject": {
          "oneOf": [
            {
              "$ref": "#/$defs/spanned_text"
            },
            {
              "type": "null"
            }
          ]
        },
        "until": {
          "oneOf": [
            {
              "$ref": "#/$defs/spanned_text"
            },
            {
              "type": "null"
            }
          ]
        },
        "raw": {
          "$ref": "#/$defs/non_empty_string"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "spanned_text": {
      "type": "object",
      "required": ["raw", "span"],
      "additionalProperties": false,
      "properties": {
        "raw": {
          "$ref": "#/$defs/non_empty_string"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "step": {
      "type": "object",
      "required": ["kind", "name", "parameters", "outputType", "effects", "requirements", "checkpoints", "approvals", "timeouts", "retries", "memoryAccesses", "span"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "Step"
        },
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameter"
          }
        },
        "outputType": {
          "$ref": "#/$defs/nullable_non_empty_string"
        },
        "outputTypeSpan": {
          "oneOf": [
            {
              "$ref": "#/$defs/span"
            },
            {
              "type": "null"
            }
          ]
        },
        "effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/effect_use"
          }
        },
        "requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statement"
          }
        },
        "checkpoints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statement"
          }
        },
        "approvals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statement"
          }
        },
        "timeouts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statement"
          }
        },
        "retries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statement"
          }
        },
        "memoryAccesses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/memory_access"
          }
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "memory_access": {
      "type": "object",
      "required": ["kind", "access", "memory", "slot", "target", "span"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "MemoryAccess"
        },
        "access": {
          "enum": ["read", "write", "cite"]
        },
        "memory": {
          "$ref": "#/$defs/non_empty_string"
        },
        "slot": {
          "$ref": "#/$defs/nullable_non_empty_string"
        },
        "target": {
          "$ref": "#/$defs/non_empty_string"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    },
    "effect_use": {
      "type": "object",
      "required": ["kind", "name", "family", "action", "args", "argKinds", "argSpans", "expression", "span"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "EffectUse"
        },
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "family": {
          "$ref": "#/$defs/non_empty_string"
        },
        "action": {
          "$ref": "#/$defs/nullable_non_empty_string"
        },
        "args": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "argKinds": {
          "type": "object",
          "additionalProperties": {
            "enum": ["string", "identifier"]
          }
        },
        "argSpans": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/span"
          }
        },
        "expression": {
          "$ref": "#/$defs/non_empty_string"
        },
        "span": {
          "$ref": "#/$defs/span"
        }
      }
    }
  }
}
