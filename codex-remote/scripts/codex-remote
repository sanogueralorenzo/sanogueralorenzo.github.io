#!/usr/bin/env bash
set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
  LINK_TARGET="$(readlink "$SOURCE_PATH")"
  if [[ "$LINK_TARGET" == /* ]]; then
    SOURCE_PATH="$LINK_TARGET"
  else
    SOURCE_PATH="$SOURCE_DIR/$LINK_TARGET"
  fi
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
STATE_DIR="${CODEX_REMOTE_STATE_DIR:-$HOME/.codex/remote}"
PID_FILE="$STATE_DIR/codex-remote.pid"
LOG_FILE="$STATE_DIR/codex-remote.log"
CAFFEINATE_PID_FILE="$STATE_DIR/codex-remote-caffeinate.pid"

print_usage() {
  cat <<USAGE
Usage:
  ./scripts/codex-remote install
  ./scripts/codex-remote start [--plain]
  ./scripts/codex-remote stop [--plain]
  ./scripts/codex-remote status [--plain]
  ./scripts/codex-remote restart [--plain]
  ./scripts/codex-remote logs [-f|--follow]

Commands:
  install    Install npm dependencies in project root.
  start      Start background bot process and persist PID/log state.
  stop       Stop managed background bot process.
  status     Print managed process status.
  restart    Stop and then start managed process.
  logs       Show recent logs (or follow with -f).

Notes:
- Default command when omitted is: start
- start runs the bot in background and writes logs to: $LOG_FILE
USAGE
}

ensure_npm() {
  if ! command -v npm >/dev/null 2>&1; then
    echo "npm not found. Install Node.js 18+ and npm." >&2
    exit 1
  fi
}

ensure_codex_sessions() {
  if ! command -v codex-sessions >/dev/null 2>&1; then
    local sibling_install="$PROJECT_ROOT/../codex-sessions/scripts/install.sh"
    echo "codex-sessions not found. Install it first:" >&2
    if [[ -f "$sibling_install" ]]; then
      echo "  $sibling_install" >&2
    else
      echo "  codex-sessions/scripts/install.sh" >&2
    fi
    exit 1
  fi
}

ensure_state_dir() {
  mkdir -p "$STATE_DIR"
}

ensure_env_file() {
  if [[ ! -f "$PROJECT_ROOT/.env" ]]; then
    echo "Missing .env in $PROJECT_ROOT" >&2
    echo "Create it with: cp .env.example .env" >&2
    exit 1
  fi
}

ensure_dependencies() {
  if [[ ! -d "$PROJECT_ROOT/node_modules" ]]; then
    echo "Dependencies missing. Running npm install..." >&2
    (cd "$PROJECT_ROOT" && npm install)
  fi
}

read_pid() {
  if [[ -f "$PID_FILE" ]]; then
    tr -d '[:space:]' < "$PID_FILE"
  fi
}

is_running() {
  local pid
  pid="$(read_pid || true)"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

read_caffeinate_pid() {
  if [[ -f "$CAFFEINATE_PID_FILE" ]]; then
    tr -d '[:space:]' < "$CAFFEINATE_PID_FILE"
  fi
}

is_macos() {
  [[ "$(uname -s)" == "Darwin" ]]
}

stop_caffeinate_if_any() {
  local pid
  pid="$(read_caffeinate_pid || true)"
  [[ -n "$pid" ]] || return 0

  if kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null || true
  fi
  rm -f "$CAFFEINATE_PID_FILE"
}

start_caffeinate_for_pid() {
  local target_pid="$1"
  stop_caffeinate_if_any

  if ! is_macos; then
    return 0
  fi
  if ! command -v caffeinate >/dev/null 2>&1; then
    return 0
  fi

  nohup caffeinate -dimsu -w "$target_pid" >/dev/null 2>&1 &
  echo $! > "$CAFFEINATE_PID_FILE"
}

clear_pid_if_stale() {
  if [[ -f "$PID_FILE" ]] && ! is_running; then
    rm -f "$PID_FILE"
    stop_caffeinate_if_any
  fi
}

output_status() {
  local plain="$1"
  clear_pid_if_stale
  if is_running; then
    local pid
    pid="$(read_pid)"
    if [[ "$plain" == "true" ]]; then
      echo "running:$pid"
    else
      echo "Running (PID $pid)"
    fi
  else
    if [[ "$plain" == "true" ]]; then
      echo "stopped"
    else
      echo "Stopped"
    fi
  fi
}

cmd_install() {
  ensure_npm
  (cd "$PROJECT_ROOT" && npm install)
  echo "Installed dependencies"
}

cmd_start() {
  local plain="$1"
  ensure_npm
  ensure_codex_sessions
  ensure_state_dir
  ensure_env_file
  ensure_dependencies

  if is_running; then
    start_caffeinate_for_pid "$(read_pid)"
    output_status "$plain"
    return 0
  fi

  (cd "$PROJECT_ROOT" && nohup npm run dev > "$LOG_FILE" 2>&1 & echo $! > "$PID_FILE")
  start_caffeinate_for_pid "$(read_pid)"
  output_status "$plain"
}

cmd_stop() {
  local plain="$1"
  clear_pid_if_stale

  if ! is_running; then
    rm -f "$PID_FILE"
    if [[ "$plain" == "true" ]]; then
      echo "stopped"
    else
      echo "Stopped"
    fi
    return 0
  fi

  local pid
  pid="$(read_pid)"
  if ! kill "$pid" 2>/dev/null; then
    echo "Failed to stop PID $pid" >&2
    exit 1
  fi

  rm -f "$PID_FILE"
  stop_caffeinate_if_any
  if [[ "$plain" == "true" ]]; then
    echo "stopped"
  else
    echo "Stopped"
  fi
}

cmd_restart() {
  local plain="$1"
  cmd_stop "true" >/dev/null
  cmd_start "$plain"
}

cmd_logs() {
  local follow="false"
  local arg="${1:-}"
  if [[ "$arg" == "-f" || "$arg" == "--follow" ]]; then
    follow="true"
  elif [[ -n "$arg" ]]; then
    echo "Unknown logs option: $arg" >&2
    print_usage >&2
    exit 1
  fi

  ensure_state_dir
  if [[ ! -f "$LOG_FILE" ]]; then
    echo "Log file not found: $LOG_FILE" >&2
    exit 1
  fi

  if [[ "$follow" == "true" ]]; then
    exec tail -n 200 -f "$LOG_FILE"
  fi

  tail -n 200 "$LOG_FILE"
}

main() {
  local command
  if [[ "$#" -gt 0 ]]; then
    command="$1"
    shift
  else
    command="start"
  fi

  case "$command" in
    help|--help|-h)
      if [[ "$#" -gt 0 ]]; then
        echo "Unexpected arguments for $command: $*" >&2
        print_usage >&2
        exit 1
      fi
      print_usage
      ;;
    install)
      if [[ "$#" -gt 0 ]]; then
        echo "Unexpected arguments for install: $*" >&2
        print_usage >&2
        exit 1
      fi
      cmd_install
      ;;
    start)
      local plain="false"
      if [[ "${1:-}" == "--plain" ]]; then
        plain="true"
        shift
      fi
      if [[ "$#" -gt 0 ]]; then
        echo "Unexpected arguments for start: $*" >&2
        print_usage >&2
        exit 1
      fi
      cmd_start "$plain"
      ;;
    stop)
      local plain="false"
      if [[ "${1:-}" == "--plain" ]]; then
        plain="true"
        shift
      fi
      if [[ "$#" -gt 0 ]]; then
        echo "Unexpected arguments for stop: $*" >&2
        print_usage >&2
        exit 1
      fi
      cmd_stop "$plain"
      ;;
    status)
      local plain="false"
      if [[ "${1:-}" == "--plain" ]]; then
        plain="true"
        shift
      fi
      if [[ "$#" -gt 0 ]]; then
        echo "Unexpected arguments for status: $*" >&2
        print_usage >&2
        exit 1
      fi
      output_status "$plain"
      ;;
    restart)
      local plain="false"
      if [[ "${1:-}" == "--plain" ]]; then
        plain="true"
        shift
      fi
      if [[ "$#" -gt 0 ]]; then
        echo "Unexpected arguments for restart: $*" >&2
        print_usage >&2
        exit 1
      fi
      cmd_restart "$plain"
      ;;
    logs)
      if [[ "$#" -gt 1 ]]; then
        echo "Unexpected arguments for logs: $*" >&2
        print_usage >&2
        exit 1
      fi
      cmd_logs "${1:-}"
      ;;
    *)
      echo "Unknown command: $command" >&2
      print_usage >&2
      exit 1
      ;;
  esac
}

main "$@"
