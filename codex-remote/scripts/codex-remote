#!/usr/bin/env bash
set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
  LINK_TARGET="$(readlink "$SOURCE_PATH")"
  if [[ "$LINK_TARGET" == /* ]]; then
    SOURCE_PATH="$LINK_TARGET"
  else
    SOURCE_PATH="$SOURCE_DIR/$LINK_TARGET"
  fi
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
STATE_DIR="${CODEX_REMOTE_STATE_DIR:-$HOME/.codex/remote}"
PID_FILE="$STATE_DIR/codex-remote.pid"
LOG_FILE="$STATE_DIR/codex-remote.log"
CAFFEINATE_PID_FILE="$STATE_DIR/codex-remote-caffeinate.pid"

COMMAND_NAMES=()
COMMAND_USAGES=()
COMMAND_DESCRIPTIONS=()
COMMAND_HANDLERS=()

register_command() {
  local name="$1"
  local usage="$2"
  local description="$3"
  local handler="$4"

  if [[ -z "$name" || -z "$usage" || -z "$description" || -z "$handler" ]]; then
    echo "Internal error: invalid command registration." >&2
    exit 1
  fi

  if command_index_by_name "$name" >/dev/null; then
    echo "Internal error: duplicated command registration '$name'." >&2
    exit 1
  fi

  COMMAND_NAMES+=("$name")
  COMMAND_USAGES+=("$usage")
  COMMAND_DESCRIPTIONS+=("$description")
  COMMAND_HANDLERS+=("$handler")
}

command_index_by_name() {
  local target="$1"
  local i
  for (( i=0; i<${#COMMAND_NAMES[@]}; i++ )); do
    if [[ "${COMMAND_NAMES[$i]}" == "$target" ]]; then
      echo "$i"
      return 0
    fi
  done
  return 1
}

init_command_registry() {
  register_command "install" "install" "Install npm dependencies in project root." "command_install"
  register_command "start" "start [--plain]" "Start background bot process and persist PID/log state." "command_start"
  register_command "stop" "stop [--plain]" "Stop managed background bot process." "command_stop"
  register_command "status" "status [--plain]" "Print managed process status." "command_status"
  register_command "restart" "restart [--plain]" "Stop and then start managed process." "command_restart"
  register_command "logs" "logs [-f|--follow]" "Show recent logs (or follow with -f)." "command_logs"
  register_command "help" "help" "Print this help output." "command_help"
}

print_usage() {
  local max_len=0
  local i
  for (( i=0; i<${#COMMAND_NAMES[@]}; i++ )); do
    if (( ${#COMMAND_NAMES[$i]} > max_len )); then
      max_len=${#COMMAND_NAMES[$i]}
    fi
  done

  echo "Usage:"
  for (( i=0; i<${#COMMAND_NAMES[@]}; i++ )); do
    echo "  ./scripts/codex-remote ${COMMAND_USAGES[$i]}"
  done
  echo
  echo "Commands:"
  for (( i=0; i<${#COMMAND_NAMES[@]}; i++ )); do
    printf "  %-*s  %s\n" "$max_len" "${COMMAND_NAMES[$i]}" "${COMMAND_DESCRIPTIONS[$i]}"
  done
  echo
  echo "Notes:"
  echo "- Default command when omitted is: start"
  echo "- start builds the app (npm run build) and runs node dist/index.js"
  echo "- start runs the bot in background and writes logs to: $LOG_FILE"
}

print_command_help_by_index() {
  local index="$1"
  local name="${COMMAND_NAMES[$index]}"
  local usage="${COMMAND_USAGES[$index]}"
  local description="${COMMAND_DESCRIPTIONS[$index]}"

  echo "Usage:"
  echo "  ./scripts/codex-remote $usage"
  echo
  echo "Description:"
  echo "  $description"

  case "$name" in
    start|stop|status|restart)
      echo
      echo "Options:"
      echo "  --plain  Print machine-readable output when supported."
      ;;
    logs)
      echo
      echo "Options:"
      echo "  -f, --follow  Stream log output continuously."
      ;;
  esac
}

print_command_help_by_name() {
  local name="$1"
  local index
  if ! index="$(command_index_by_name "$name")"; then
    echo "Unknown command: $name" >&2
    print_usage >&2
    exit 1
  fi
  print_command_help_by_index "$index"
}

ensure_npm() {
  if ! command -v npm >/dev/null 2>&1; then
    echo "npm not found. Install Node.js 18+ and npm." >&2
    exit 1
  fi
}

ensure_node() {
  if ! command -v node >/dev/null 2>&1; then
    echo "node not found. Install Node.js 18+." >&2
    exit 1
  fi
}

ensure_codex_app_server() {
  if ! command -v codexhub >/dev/null 2>&1; then
    local sibling_install="$PROJECT_ROOT/../codexhub/scripts/install.sh"
    echo "codexhub not found. Install it first:" >&2
    if [[ -f "$sibling_install" ]]; then
      echo "  $sibling_install" >&2
    else
      echo "  codexhub/scripts/install.sh" >&2
    fi
    exit 1
  fi
}

ensure_state_dir() {
  mkdir -p "$STATE_DIR"
}

ensure_env_file() {
  if [[ ! -f "$PROJECT_ROOT/.env" ]]; then
    echo "Missing .env in $PROJECT_ROOT" >&2
    echo "Create it with: cp .env.example .env" >&2
    exit 1
  fi
}

ensure_dependencies() {
  if [[ ! -d "$PROJECT_ROOT/node_modules" ]]; then
    echo "Dependencies missing. Running npm install..." >&2
    (cd "$PROJECT_ROOT" && npm install)
  fi
}

read_pid() {
  if [[ -f "$PID_FILE" ]]; then
    tr -d '[:space:]' < "$PID_FILE"
  fi
}

is_running() {
  local pid
  pid="$(read_pid || true)"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

list_codex_remote_runtime_pids() {
  /bin/ps -axo pid=,command= | while IFS= read -r pid command; do
    [[ -n "$pid" && -n "${command:-}" ]] || continue
    if [[ "$command" == *"$PROJECT_ROOT/node_modules/.bin/tsx watch src/index.ts"* ]]; then
      echo "$pid"
      continue
    fi
    if [[ "$command" == *"$PROJECT_ROOT/node_modules/tsx/dist/loader.mjs src/index.ts"* ]]; then
      echo "$pid"
      continue
    fi
  done | sort -n | uniq
}

print_stopped_status() {
  local plain="$1"
  if [[ "$plain" == "true" ]]; then
    echo "stopped"
  else
    echo "Stopped"
  fi
}

kill_pid_with_grace() {
  local pid="$1"
  kill -TERM "$pid" 2>/dev/null || return 0

  local retries=20
  while (( retries > 0 )); do
    if ! kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
    sleep 0.1
    retries=$((retries - 1))
  done

  kill -KILL "$pid" 2>/dev/null || true
}

kill_codex_remote_runtime_pids_excluding() {
  local exclude_pid="${1:-}"
  local pid
  while IFS= read -r pid; do
    [[ -n "$pid" ]] || continue
    if [[ -n "$exclude_pid" && "$pid" == "$exclude_pid" ]]; then
      continue
    fi
    kill_pid_with_grace "$pid"
  done < <(list_codex_remote_runtime_pids)
}

read_caffeinate_pid() {
  if [[ -f "$CAFFEINATE_PID_FILE" ]]; then
    tr -d '[:space:]' < "$CAFFEINATE_PID_FILE"
  fi
}

is_macos() {
  [[ "$(uname -s)" == "Darwin" ]]
}

stop_caffeinate_if_any() {
  local pid
  pid="$(read_caffeinate_pid || true)"
  [[ -n "$pid" ]] || return 0

  if kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null || true
  fi
  rm -f "$CAFFEINATE_PID_FILE"
}

start_caffeinate_for_pid() {
  local target_pid="$1"
  stop_caffeinate_if_any

  if ! is_macos; then
    return 0
  fi
  if ! command -v caffeinate >/dev/null 2>&1; then
    return 0
  fi

  nohup caffeinate -dimsu -w "$target_pid" >/dev/null 2>&1 &
  echo $! > "$CAFFEINATE_PID_FILE"
}

clear_pid_if_stale() {
  if [[ -f "$PID_FILE" ]] && ! is_running; then
    rm -f "$PID_FILE"
    stop_caffeinate_if_any
  fi
}

output_status() {
  local plain="$1"
  clear_pid_if_stale
  if is_running; then
    local pid
    pid="$(read_pid)"
    if [[ "$plain" == "true" ]]; then
      echo "running:$pid"
    else
      echo "Running (PID $pid)"
    fi
  else
    if [[ "$plain" == "true" ]]; then
      echo "stopped"
    else
      echo "Stopped"
    fi
  fi
}

cmd_install() {
  ensure_npm
  (cd "$PROJECT_ROOT" && npm install)
  echo "Installed dependencies"
}

cmd_start() {
  local plain="$1"
  ensure_npm
  ensure_node
  ensure_codex_app_server
  ensure_state_dir
  ensure_env_file
  ensure_dependencies
  (cd "$PROJECT_ROOT" && npm run build >/dev/null)
  clear_pid_if_stale

  local managed_pid
  managed_pid="$(read_pid || true)"
  kill_codex_remote_runtime_pids_excluding "$managed_pid"

  if is_running; then
    start_caffeinate_for_pid "$(read_pid)"
    output_status "$plain"
    return 0
  fi

  (
    cd "$PROJECT_ROOT"
    nohup node dist/index.js > "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
  )
  start_caffeinate_for_pid "$(read_pid)"
  output_status "$plain"
}

cmd_stop() {
  local plain="$1"
  clear_pid_if_stale

  local managed_pid
  managed_pid="$(read_pid || true)"
  if ! is_running; then
    rm -f "$PID_FILE"
    kill_codex_remote_runtime_pids_excluding ""
    print_stopped_status "$plain"
    return 0
  fi

  if [[ -n "$managed_pid" ]]; then
    kill_pid_with_grace "$managed_pid"
  fi

  kill_codex_remote_runtime_pids_excluding ""
  rm -f "$PID_FILE"
  stop_caffeinate_if_any
  print_stopped_status "$plain"
}

cmd_restart() {
  local plain="$1"
  cmd_stop "true" >/dev/null
  cmd_start "$plain"
}

cmd_logs() {
  local follow="false"
  local arg="${1:-}"
  if [[ "$arg" == "-f" || "$arg" == "--follow" ]]; then
    follow="true"
  elif [[ -n "$arg" ]]; then
    echo "Unknown logs option: $arg" >&2
    print_usage >&2
    exit 1
  fi

  ensure_state_dir
  if [[ ! -f "$LOG_FILE" ]]; then
    echo "Log file not found: $LOG_FILE" >&2
    exit 1
  fi

  if [[ "$follow" == "true" ]]; then
    exec tail -n 200 -f "$LOG_FILE"
  fi

  tail -n 200 "$LOG_FILE"
}

command_help() {
  if [[ "$#" -eq 0 ]]; then
    print_usage
    return
  fi
  if [[ "$#" -eq 1 ]]; then
    print_command_help_by_name "$1"
    return
  fi
  echo "Unexpected arguments for help: $*" >&2
  print_usage >&2
  exit 1
}

command_install() {
  if [[ "$#" -gt 0 ]]; then
    echo "Unexpected arguments for install: $*" >&2
    print_usage >&2
    exit 1
  fi
  cmd_install
}

command_start() {
  local plain="false"
  if [[ "${1:-}" == "--plain" ]]; then
    plain="true"
    shift
  fi
  if [[ "$#" -gt 0 ]]; then
    echo "Unexpected arguments for start: $*" >&2
    print_usage >&2
    exit 1
  fi
  cmd_start "$plain"
}

command_stop() {
  local plain="false"
  if [[ "${1:-}" == "--plain" ]]; then
    plain="true"
    shift
  fi
  if [[ "$#" -gt 0 ]]; then
    echo "Unexpected arguments for stop: $*" >&2
    print_usage >&2
    exit 1
  fi
  cmd_stop "$plain"
}

command_status() {
  local plain="false"
  if [[ "${1:-}" == "--plain" ]]; then
    plain="true"
    shift
  fi
  if [[ "$#" -gt 0 ]]; then
    echo "Unexpected arguments for status: $*" >&2
    print_usage >&2
    exit 1
  fi
  output_status "$plain"
}

command_restart() {
  local plain="false"
  if [[ "${1:-}" == "--plain" ]]; then
    plain="true"
    shift
  fi
  if [[ "$#" -gt 0 ]]; then
    echo "Unexpected arguments for restart: $*" >&2
    print_usage >&2
    exit 1
  fi
  cmd_restart "$plain"
}

command_logs() {
  if [[ "$#" -gt 1 ]]; then
    echo "Unexpected arguments for logs: $*" >&2
    print_usage >&2
    exit 1
  fi
  cmd_logs "${1:-}"
}

dispatch_command() {
  local command="$1"
  shift

  if [[ "$command" == "--help" || "$command" == "-h" ]]; then
    command="help"
  fi

  if [[ "$command" != "help" ]]; then
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      shift
      if [[ "$#" -gt 0 ]]; then
        echo "Unexpected arguments for $command --help: $*" >&2
        exit 1
      fi
      print_command_help_by_name "$command"
      return
    fi
  fi

  local index
  if ! index="$(command_index_by_name "$command")"; then
    echo "Unknown command: $command" >&2
    print_usage >&2
    exit 1
  fi

  local handler="${COMMAND_HANDLERS[$index]}"
  if ! declare -F "$handler" >/dev/null 2>&1; then
    echo "Internal error: handler '$handler' is not implemented for command '$command'." >&2
    exit 1
  fi

  "$handler" "$@"
}

main() {
  init_command_registry

  local command="start"
  if [[ "$#" -gt 0 ]]; then
    command="$1"
    shift
  fi

  dispatch_command "$command" "$@"
}

main "$@"
