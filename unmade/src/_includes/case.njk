---
layout: base.njk
---
<main class="case-page">
  <nav class="topbar" aria-label="Unmade navigation">
    <a class="wordmark" href="/unmade/">Unmade</a>
    <a class="home-link" href="/unmade/#archive">Archive</a>
  </nav>

  <article class="case-file">
    <header class="case-header">
      <p class="kicker">{{ category }} / {{ status }}</p>
      <h1>{{ title }}</h1>
      <p>{{ excerpt }}</p>
    </header>

    <section class="artifact-panel" aria-label="Artifact details">
      <div class="artifact-visual artifact-{{ visual }}">
        <img src="{{ image or ('/unmade/assets/images/topic-' ~ (category | lower) ~ '.png') }}" alt="{{ imageAlt or category ~ ' visual study' }}">
      </div>

      <dl class="case-notes">
        <div>
          <dt>Category</dt>
          <dd>{{ category }}</dd>
        </div>
        <div>
          <dt>State</dt>
          <dd>{{ status }}</dd>
        </div>
        <div>
          <dt>Trace</dt>
          <dd>{{ trace }}</dd>
        </div>
        {% if materials %}
          <div>
            <dt>Materials</dt>
            <dd>{{ materials }}</dd>
          </div>
        {% endif %}
        {% if provenance %}
          <div>
            <dt>Provenance</dt>
            <dd>{{ provenance }}</dd>
          </div>
        {% endif %}
        <div>
          <dt>Question</dt>
          <dd>{{ question }}</dd>
        </div>
      </dl>
    </section>

    <section class="case-body prose">
      {{ content | safe }}
    </section>
  </article>
</main>
