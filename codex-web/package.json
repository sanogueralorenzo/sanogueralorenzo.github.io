{
  "name": "codex-web",
  "private": true,
  "type": "module",
  "bin": {
    "codex-web": "./dist/src/server.js"
  },
  "scripts": {
    "build": "tsc && cp dist/src/client.js public/client.js",
    "dev": "npm run build && node dist/src/server.js",
