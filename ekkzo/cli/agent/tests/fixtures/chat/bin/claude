#!/bin/sh
if [ "$1" = "--version" ]; then
  echo "claude-fake"
  exit 0
fi

session_id="anthropic-session-new"
while [ "$#" -gt 0 ]; do
  if [ "$1" = "--resume" ]; then
    session_id="$2"
    shift 2
    continue
  fi
  shift
done

input=""
while IFS= read -r line; do
  input="$input$line"
done

echo "{\"type\":\"system\",\"subtype\":\"init\",\"session_id\":\"$session_id\"}"
echo "{\"type\":\"assistant\",\"session_id\":\"$session_id\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"anthropic-success\"}]}}"

if printf '%s' "$input" | grep -q 'FAIL'; then
  echo "{\"type\":\"result\",\"session_id\":\"$session_id\",\"is_error\":true,\"result\":\"anthropic-failed\",\"error\":\"anthropic_code\",\"stop_reason\":\"stop_sequence\",\"terminal_reason\":\"completed\"}"
else
  echo "{\"type\":\"result\",\"session_id\":\"$session_id\",\"is_error\":false,\"result\":\"done\",\"stop_reason\":\"end_turn\",\"terminal_reason\":\"completed\"}"
fi

exit 0
