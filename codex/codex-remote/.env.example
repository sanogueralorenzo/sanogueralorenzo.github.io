TELEGRAM_BOT_TOKEN=123456:replace-with-your-bot-token
# Optional allowlist. Comma-separated Telegram chat IDs.
# If omitted, all chats can interact with the bot.
TELEGRAM_ALLOWED_CHAT_IDS=1234567890

# Optional. Defaults to $HOME/.codex if omitted.
# Supports: ~, $HOME, ${HOME}, absolute path.
# CODEX_HOME=$HOME/.codex

# Where Codex should run commands/files.
# Optional. Defaults to $HOME if omitted.
# Supports: ~, $HOME, ${HOME}, absolute path.
# CODEX_WORKING_DIRECTORY=$HOME

# Optional Codex runtime behavior.
# Any model id supported by your Codex setup.
# CODEX_MODEL=gpt-5-codex
#
# Access mode presets (pick one set):
#
# 1) Read-only (safest)
# CODEX_APPROVAL_POLICY=on-request
# CODEX_SANDBOX_MODE=read-only
# CODEX_NETWORK_ACCESS_ENABLED=false
#
# 2) Workspace write (recommended middle ground)
# CODEX_APPROVAL_POLICY=on-request
# CODEX_SANDBOX_MODE=workspace-write
# CODEX_NETWORK_ACCESS_ENABLED=true
#
# 3) Full access (most permissive)
# CODEX_APPROVAL_POLICY=never
# CODEX_SANDBOX_MODE=danger-full-access
# CODEX_NETWORK_ACCESS_ENABLED=true
#
# Allowed values:
# CODEX_APPROVAL_POLICY: untrusted | on-request | on-failure | never
# CODEX_SANDBOX_MODE: read-only | workspace-write | danger-full-access
# CODEX_NETWORK_ACCESS_ENABLED: false | true

# Voice-message transcription (local/on-device) is always enabled.
# The bot always uses ./scripts/transcribe-whispercpp.sh internally.
# Optional explicit path to whisper-cli binary.
# If unset, transcriber checks PATH and common install locations.
# WHISPER_CLI_BIN=/opt/homebrew/bin/whisper-cli
# Optional override for scripts/transcribe-whispercpp.sh (tiny-only):
# If unset, default is ./models/ggml-tiny.en.bin
# WHISPER_MODEL_PATH_TINY=$HOME/AndroidStudioProjects/sanogueralorenzo.github.io/codex-remote/models/ggml-tiny.en.bin

# Fixed defaults (not configurable via env):
# - CODEX_SKIP_GIT_REPO_CHECK=true
# - BINDINGS_FILE=runtime/bindings.json
# - TELEGRAM_VOICE_ECHO_TRANSCRIPT=false
# - TELEGRAM_DRAFT_STREAMING=true
# - TELEGRAM_DRAFT_THROTTLE_MS=500
# - TELEGRAM_APPROVAL_DEFAULT_DECISION=decline
